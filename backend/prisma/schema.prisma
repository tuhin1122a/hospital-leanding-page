generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  DOCTOR
  RECEPTIONIST
  PHARMACIST
  STAFF
  PATIENT
}

model User {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  email          String         @unique
  name           String?
  password       String
  role           Role           @default(USER)
  permissions    String[]       @default(["READ"])
  profilePic     String?
  refreshToken   String?
  twoFactorSecret String?
  twoFactorEnabled Boolean      @default(false)
  lastActive     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  loginHistory   LoginHistory[]
  notifications  Notification[]
  sentMessages      Message[]    @relation("SentMessages")
  receivedMessages  Message[]    @relation("ReceivedMessages")
  salaries          Salary[]     @relation("UserSalaries")
  baseSalary        Float?       @default(0)
}

model Message {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  senderId    String   @db.ObjectId
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId  String?  @db.ObjectId
  receiver    User?    @relation("ReceivedMessages", fields: [receiverId], references: [id])
  content     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model LoginHistory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ip        String?
  userAgent String?
  device    String?
  browser   String?
  os        String?
  success   Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Patient {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  patientId    String        @unique
  name         String
  email        String?
  phone        String
  gender       String
  age          Int
  bloodGroup   String?
  address      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  admissions   Admission[]
  appointments Appointment[]
  billings     Billing[]
  records      MedicalRecord[]
  labTests     LabTest[]
}

model MedicalRecord {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  patientId   String   @db.ObjectId
  patient     Patient  @relation(fields: [patientId], references: [id])
  doctorId    String?  @db.ObjectId
  diagnosis   String
  symptoms    String?
  notes       String?
  vitals      Json?    // {bp: "120/80", temp: "98.6", pulse: "72"}
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LabTest {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  patientId   String   @db.ObjectId
  patient     Patient  @relation(fields: [patientId], references: [id])
  testName    String
  category    String?
  result      String?
  status      String   @default("PENDING") // PENDING, COMPLETED, CANCELLED
  reportUrl   String?
  date        DateTime @default(now())
}

model Admission {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  patientId     String    @db.ObjectId
  patient       Patient   @relation(fields: [patientId], references: [id])
  admissionDate DateTime  @default(now())
  dischargeDate DateTime?
  wardNo        String
  bedNo         String
  doctorInCharge String
  status        String    @default("ADMITTED")
  reason        String?
}

model Appointment {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  patientId       String   @db.ObjectId
  patient         Patient  @relation(fields: [patientId], references: [id])
  doctorName      String
  department      String
  appointmentDate DateTime
  serialNo        Int?
  status          String   @default("PENDING")
  fee             Float
}

model Billing {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  patientId     String   @db.ObjectId
  patient       Patient  @relation(fields: [patientId], references: [id])
  invoiceNo     String   @unique
  totalAmount   Float
  discount      Float    @default(0)
  paidAmount    Float
  dueAmount     Float
  status        String   @default("UNPAID")
  items         Json?
  createdAt     DateTime @default(now())
}

model ApprovalRequest {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  requestedBy   String   @db.ObjectId
  type          String
  description   String
  amount        Float?
  status        String   @default("PENDING")
  referenceId   String?
  createdAt     DateTime @default(now())
  actionDate    DateTime?
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  user      User?    @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("INFO") // INFO, WARNING, SUCCESS, URGENT
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
model Salary {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation("UserSalaries", fields: [userId], references: [id])
  amount      Float
  month       Int      // 1-12
  year        Int
  status      String   @default("PAID") // PAID, PENDING
  note        String?
  paymentDate DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
